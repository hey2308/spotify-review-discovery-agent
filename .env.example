# Application
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Local SQLite database (path is relative to project root)
# Production (Render): postgresql://… is auto-normalized to postgresql+psycopg://…
DATABASE_URL=sqlite+pysqlite:///../data/spotify_discovery.db

# Groq LLM (omit to run in mock mode)
GROQ_API_KEY=
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile

# Embeddings (local sentence-transformers — Phase 2C default)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_TEXT_CHARS=2000

# ChromaDB (embedded, one-time analysis run)
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=feedback_embeddings

# CORS (comma-separated origins for Vercel frontend)
# Production example: https://your-project.vercel.app
CORS_ORIGINS=http://localhost:5173

# Frontend (Vite) — set VITE_API_BASE_URL on Vercel; see frontend/.env.example
VITE_API_BASE_URL=http://localhost:8000

# Reddit (optional — required only for live Reddit fetch)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=spotify-discovery-agent/0.1

# Spotify Community RSS feed
COMMUNITY_FEED_URL=https://community.spotify.com/rss/message?board.id=iOS_iPhone_iPad

# Delay between live source requests (seconds)
INGEST_THROTTLE_SECONDS=0.5
INGEST_MIN_WORDS=6
INGEST_ENGLISH_ONLY=true

# Play Store pagination (continuation-token loop; stops at max or 6-month window)
PLAY_STORE_MAX_REVIEWS=3000
PLAY_STORE_PAGE_SIZE=200

# Social ingestion (public endpoints — no auth)
# Bluesky: api.bsky.app search with since/until time-slice pagination (cursor blocked unauthenticated)
BLUESKY_SEARCH_QUERIES=spotify discovery,spotify recommendations,spotify algorithm,spotify discover weekly,spotify playlist,spotify shuffle,spotify radio,spotify repeat,spotify stale,spotify wrapped,spotify release radar,spotify daily mix,spotify autoplay,spotify home feed,spotify bad recommendations,spotify find new music,spotify music discovery
BLUESKY_PAGE_SIZE=100
BLUESKY_SLICE_DAYS=14
# Mastodon: public tag timelines with max_id pagination
MASTODON_INSTANCES=https://mastodon.social,https://mastodon.online,https://fosstodon.org,https://mas.to,https://hachyderm.io,https://techhub.social
MASTODON_TAGS=spotifydiscovery,discoverweekly,spotify
MASTODON_PAGE_SIZE=40
MASTODON_MAX_PAGES=50
SOCIAL_MAX_ITEMS=3000

# Groq rate limits (stay under tier caps; 70B: 30 RPM / 1K RPD / 12K TPM / 100K TPD)
GROQ_SMALL_RPM=25
GROQ_LARGE_RPM=25
GROQ_MAX_RETRIES=2
CLASSIFICATION_BATCH_SIZE=16
CLASSIFICATION_MAX_TEXT_CHARS=400

# Theme clustering (UMAP + HDBSCAN — Phase 2D)
MAX_THEMES=5
UMAP_N_NEIGHBORS=15
UMAP_N_COMPONENTS=5
UMAP_MIN_DIST=0.0
UMAP_RANDOM_STATE=42
HDBSCAN_MIN_CLUSTER_SIZE=30
# HDBSCAN_MIN_SAMPLES=  # optional; defaults to min_cluster_size when unset

# Theme labeling & evidence (Phase 2E/2F)
THEME_LABEL_QUOTE_COUNT=8
THEME_REPRESENTATIVE_QUOTES=5
ANALYSIS_EXPORT_DIR=../data/analyzed

# Discovery intelligence (Phase 3)
QA_RETRIEVAL_COUNT=20
QA_SYNTHESIS_QUOTE_COUNT=10
QA_MIN_EVIDENCE=3
SEGMENT_MIN_ITEMS=5
UNMET_NEEDS_RETRIEVAL_COUNT=30
UNMET_NEEDS_MAX_ITEMS=8
